APP_NAME=YouCode AI Guide
APP_ENV=development
APP_DEBUG=true

GOOGLE_API_KEY=replace-with-your-api-key
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=youcode_documents
PARENT_STORE_PATH=data/database/parent_documents.json

DATABASE_URL=sqlite:///data/database/youcode.db
DOCUMENTS_PATH=data/documents

RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.55

MAX_HISTORY_MESSAGES=12

CONSENT_VERSION=2026-01
CONSENT_TOKEN_TTL_MINUTES=30
CONSENT_SECRET_KEY=generate-a-random-secret